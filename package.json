{
	"name": "@printf83/bsts",
	"version": "1.1.10",
	"packageManager": "pnpm@10.32.1",
	"description": "Bootstrap TS builder",
	"keywords": [
		"bootstrap 5",
		"typescript"
	],
	"author": "Hamzah A <printf83@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/printf83/bsts/issues"
	},
	"homepage": "https://github.com/printf83/bsts#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/printf83/bsts.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "./build/cjs/index.cjs",
	"module": "./build/esm/index.mjs",
	"types": "./build/types/index.d.ts",
	"exports": {
		".": {
			"types": "./build/types/index.d.ts",
			"require": "./build/cjs/index.cjs",
			"import": "./build/esm/index.mjs",
			"default": "./build/esm/index.mjs"
		}
	},
	"unpkg": "./dist/bsts.bundle.js",
	"files": [
		"build/",
		"dist/",
		"src/",
		"README.md"
	],
	"engines": {
		"node": ">=26.1.0"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^25.0.8",
		"@rollup/plugin-node-resolve": "^15.3.1",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^11.1.6",
		"@total-typescript/ts-reset": "^0.4.2",
		"@types/bootstrap": "^5.2.10",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"eslint": "^10.3.0",
		"prettier": "^3.8.3",
		"rollup": "^3.30.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@popperjs/core": "^2.11.8",
		"bootstrap": "^5.3.8"
	},
	"scripts": {
		"link": "pnpm link",
		"clean": "node ./scripts/clean.mjs",
		"build:types": "tsc -p ./tsconfig.types.json",
		"build:js": "rollup --config rollup.config.mjs",
		"build": "pnpm run clean && pnpm run build:js && pnpm run build:types",
		"prepare": "pnpm run build",
		"demo": "node ./scripts/demo.mjs",
		"lint": "eslint . --ext .ts,.mjs",
		"format": "prettier --write \"src/**/*.{js,ts,html,json,md}\" \"demo/**/*.{js,ts,html,json,md}\"",
		"rebuild": "pnpm run build"
	}
}
