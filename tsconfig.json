{
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */ 
    "target": "ES2019",
    "lib": ["ES2019", "DOM"],
    "module": "commonjs",
    "outDir": "./build",
    "rootDir": "./src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
